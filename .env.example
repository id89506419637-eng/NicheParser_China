# NicheParser_China — Environment Variables
# Скопируй этот файл как .env и заполни значения

# === Flask ===
SECRET_KEY=change-me-to-random-string-at-least-32-chars
FLASK_DEBUG=0
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# === OpenRouter (AI-классификация) ===
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Модель можно выбрать: google/gemini-2.0-flash-001, anthropic/claude-3.5-haiku, openai/gpt-4o-mini
AI_MODEL=google/gemini-2.0-flash-001

# === Yandex.Direct (Wordstat) ===
# Получить: direct.yandex.ru → oauth.yandex.ru
# Пока токена нет — оставь пустым, парсер возьмёт mock-данные
YANDEX_OAUTH_TOKEN=
USE_MOCK_WORDSTAT=1

# === Модули (флаги включения) ===
ENABLE_WORDSTAT=1
ENABLE_ALIBABA=1
ENABLE_AVITO=0

# === Переопределение настроек ВЭД (опционально) ===
# VAT_PERCENT=22.0
# DEFAULT_DUTY_PERCENT=10.0
# MIN_MARGIN_PERCENT=50.0
# MIN_MARGIN_TOTAL_RUB=100000
